{
  "name": "apperio",
  "version": "1.2.2",
  "description": "This is a Node.js SDK that sends metrics to the Apperio platform.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "start:example": "ts-node example/data-sanitization-example.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:unit": "vitest run --exclude tests/integration.test.ts"
  },
  "files": [
    "dist/index.cjs",
    "dist/index.cjs.map",
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.d.ts",
    "dist/index.d.mts"
  ],
  "keywords": [
    "logger",
    "metrics",
    "monitor",
    "track",
    "apperio",
    "sdk",
    "logging"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Stanwukong/loghive-sdk.git"
  },
  "homepage": "https://github.com/Stanwukong/loghive-sdk#readme",
  "bugs": {
    "url": "https://github.com/Stanwukong/loghive-sdk/issues"
  },
  "publishConfig": {
    "@stanwukong:registry": "https://npm.pkg.github.com"
  },
  "author": "Stanwukong",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.x.x",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "ts-node": "^10.x.x",
    "tsup": "^8.5.1",
    "typescript": "^5.x.x",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "axios": "^1.x.x",
    "dotenv": "^17.2.1"
  }
}
